<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Core Permissions ──────────────────────────────────────────────── -->
    <!-- Required for foreground service (VPN notification) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Android 14+: Required foreground service type for VPN apps.
         Must match foregroundServiceType in <service> declaration.
         SPECIAL_USE is for VPN services that don't fit standard categories.
         A property declaration is also required for Play Store. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Android 14+: Required for foreground service type compatibility -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Network state access for connectivity checks -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Internet access for ZeroTier P2P communication -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 13+: Notification permission (exempt for foreground services) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock to keep CPU alive during VPN tunnel operation.
         Prevents the OS from suspending the VPN service when the
         screen is off, which would kill ZeroTier connectivity. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ── Application ───────────────────────────────────────────────────── -->
    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:supportsRtl="true">

        <!-- ── Main Activity ──────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── VPN Tunnel Service ─────────────────────────────────────── -->
        <!--
            CRITICAL PERMISSION NOTES:

            1. BIND_VPN_SERVICE: Required for Android to recognize this as a VPN service.
               Without it, VpnService.prepare() returns null and the VPN cannot be established.

            2. foregroundServiceType="specialUse": Required on Android 14+ (API 34).
               Must match the FOREGROUND_SERVICE_SPECIAL_USE permission.
               The startForeground() call in VpnNotificationHelper passes
               ServiceInfo.FOREGROUND_SERVICE_TYPE_SPECIAL_USE on API 34+.

            3. The <intent-filter> with android.net.VpnService binds this service
               to the Android VPN framework, enabling the system VPN dialog.
        -->
        <service
            android:name=".VpnTunnelService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <!-- Android 14+: Required property for SPECIAL_USE foreground service type -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpn_tunnel" />
        </service>

        <!-- ── VPN Stop Receiver ──────────────────────────────────────── -->
        <receiver
            android:name=".VpnStopReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.vpnengine.nativecore.ACTION_STOP_VPN" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
